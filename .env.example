# Copy to .env and fill in — NEVER commit real keys (repo is public!)

# Resend — contact form
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
CONTACT_TO_EMAIL=where-enquiries-should-arrive@example.com
# Optional: verified sender (defaults to onboarding@resend.dev for testing)
CONTACT_FROM_EMAIL=

# Brevo — newsletter
BREVO_API_KEY=xkeysib-xxxxxxxxxxxxxxxxxxxxxxxx
BREVO_LIST_ID=2

# Admin dashboard
ADMIN_EMAIL=admin@example.com
SESSION_SECRET=64-random-hex-chars

# Site settings editing (admin commits settings.json via GitHub API)
GITHUB_TOKEN=github_pat_xxxxxxxx
GITHUB_REPO=dgseastbourne/dgs

# Monthly client report (optional)
REPORT_TO_EMAIL=client@example.com
# Brevo list where contact-form leads are stored (create a list in Brevo, put its ID here)
BREVO_LEADS_LIST_ID=
# Protects the cron endpoint (any long random string; Vercel sends it automatically)
CRON_SECRET=

# Page-view statistics (added automatically when Upstash Redis is connected in Vercel Storage)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
